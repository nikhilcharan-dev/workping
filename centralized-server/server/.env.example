# WorkPing Core API — Environment Variables
# Copy this file to .env and fill in the values

# Server
PORT=5000
MODE=development
# MODE=production

# URLs
CLIENT_URL=http://localhost:5173
APP_URL=http://localhost:5000

# Default password assigned to new employees on account creation
USER_DEFAULT_PASSWORD=

# ─── Secrets ───────────────────────────────────────────────
SECRET_KEY=
JWT_EXPIRES_IN=7d

# ─── MongoDB Atlas ─────────────────────────────────────────
MONGODB_URI=mongodb+srv://<user>:<pass>@cluster.mongodb.net/<db>?retryWrites=true&w=majority

# ─── Internal Microservice URLs ────────────────────────────
IMAGE_CLASSIFICATION_URI=http://localhost:8001   # workping-biometric

# PhonePe gateway microservice
PHONE_PE=http://localhost:3001
PHONEPE_SECRET=

# WhatsApp microservice
WHATSAPP_URI=http://localhost:3002
WHATSAPP_SECRET=
INTERNAL_SECRET=

# ─── Redis ─────────────────────────────────────────────────
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=

# ─── Mailer (OTP) microservice ─────────────────────────────
MAIL_SERVICE_URI=http://localhost:3003
MAIL_SERVICE_KEY=

# ─── Oracle Cloud Object Storage ───────────────────────────
ORACLE_CLOUD_URI=http://localhost:8000
ORACLE_API_KEY=
ORACLE_BUCKET_PROFILES=workping-profiles
ORACLE_BUCKET_ORG_LOGOS=workping-logos

# ─── Google OAuth2 ─────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:5000/auth/google/callback

# ─── Microsoft OAuth2 ──────────────────────────────────────
MS_CLIENT_ID=
MS_OBJECT_ID=
MS_CLIENT_SECRET=
MS_REDIRECT_URI=http://localhost:5000/auth/microsoft/callback
