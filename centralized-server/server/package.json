{
  "name": "server",
  "version": "1.0.0",
  "description": "WorkPing Core API — Express 5 + MongoDB + Redis + Socket.io cluster. JWT auth with Redis-backed token revocation, TOTP 2FA, Google/Microsoft OAuth2, RBAC (admin/manager/employee), subscription billing via PhonePe webhooks, attendance/leave/shift/holiday management, multi-tenant organisation isolation, Prometheus metrics, Winston logging, Jest unit + integration tests against a Docker MongoDB replica set.",
  "type": "module",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "seed:demo": "node seedAdminUser.js",
    "seed:live": "node seedData.js",
    "test": "cross-env NODE_OPTIONS=--experimental-vm-modules jest",
    "test:integration": "cross-env NODE_OPTIONS=--experimental-vm-modules jest --config jest.integration.config.js --runInBand",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "k8s:apply": "kubectl apply -f ../../k8s/api/",
    "k8s:rollout": "kubectl rollout status deployment/workping-api",
    "k8s:scale": "kubectl scale deployment/workping-api --replicas=3"
  },
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@socket.io/redis-adapter": "^8.3.0",
    "axios": "^1.13.2",
    "bcrypt": "^6.0.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^17.2.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.1.0",
    "form-data": "^4.0.5",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.3",
    "lodash": "^4.17.23",
    "module-alias": "^2.2.3",
    "mongoose": "^9.6.2",
    "morgan": "^1.10.1",
    "multer": "^2.0.2",
    "node-cron": "^4.2.1",
    "nodemailer": "^7.0.12",
    "prom-client": "^15.1.3",
    "qrcode": "^1.5.4",
    "redis": "^5.10.0",
    "socket.io": "^4.8.3",
    "speakeasy": "^2.0.0",
    "winston": "^3.19.0",
    "winston-logstash-transport": "^2.0.0",
    "xlsx": "^0.18.5"
  },
  "imports": {
    "#webRoutes/*": "./routes/web/*",
    "#appRoutes/*": "./routes/app/*",
    "#appController/*": "./controllers/app/*",
    "#webController/*": "./controllers/web/*",
    "#models/*": "./models/*",
    "#utils/*": "./utils/*",
    "#middleware/*": "./middleware/*",
    "#adminHelper/*": "./helpers/admin/*",
    "#config/*": "./config/*",
    "#helpers/*": "./helpers/*",
    "#services/*": "./services/*"
  },
  "devDependencies": {
    "@testcontainers/mongodb": "^10.0.0",
    "testcontainers": "^10.0.0",
    "@eslint/js": "^9.0.0",
    "cross-env": "^7.0.3",
    "eslint": "^9.0.0",
    "globals": "^15.0.0",
    "jest": "^29.0.0",
    "nodemon": "^3.1.11",
    "prettier": "^3.0.0",
    "supertest": "^7.0.0"
  }
}
