# Environment Configuration Template
# IMPORTANT: NEVER commit .env files to version control
# Copy this to .env and fill in real values from secure credential vault

# === Application ===
NODE_ENV=production
PORT=3000

# === Database ===
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<database>

# === Authentication & Secrets ===
# Generate with: openssl rand -base64 32
SECRET_KEY=<generate-with-openssl-rand-base64-32>
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d
INTERNAL_SECRET=<generate-with-crypto-randomBytes>

# === 2FA & OTP ===
TWO_FA_ISSUER=WorkPing

# === WhatsApp Service ===
WHATSAPP_API_URL=https://graph.instagram.com/v12.0
WHATSAPP_PHONE_NUMBER_ID=<get-from-meta-business>
WHATSAPP_VERIFY_TOKEN=<generate-random-32-chars-minimum>
WHATSAPP_API_KEY=<meta-access-token-from-business-manager>

# === Email Service ===
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=<noreply@workping.live>
SMTP_PASSWORD=<app-specific-password>
SENDER_EMAIL=noreply@workping.live
SENDER_NAME=WorkPing

# === Redis ===
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=<generate-strong-password>

# === AWS (for LLM - Bedrock) ===
# Rotate keys regularly via AWS IAM
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=<minimum-privilege-key>
AWS_SECRET_ACCESS_KEY=<associate-secret>

# === PhonePe Gateway ===
PHONEPE_CLIENT_ID=<from-phonepe-merchant-dashboard>
PHONEPE_CLIENT_SECRET=<generate-secure-secret>
PHONEPE_BASE_URL=https://api.phonepe.com/apis/pg
WEBHOOK_SECRET=<generate-random-32-chars>
WEBHOOK_USERNAME=<secure-username>
WEBHOOK_PASSWORD=<bcrypt-hash-of-password>

# === OCI Object Storage ===
COMPARTMENT_ID=<oci-compartment>
REGION=ap-mumbai-1
API_KEY=<oci-api-key-path>

# === Dashboard Credentials ===
# Generate hash with: node -e "const b=require('bcryptjs');console.log(b.hashSync('password',12))"
DASHBOARD_USER=admin
DASHBOARD_PASS_HASH=$2b$12$<bcrypt-hash-here>

# === LLM Provider (Ollama/Bedrock) ===
LLM_PROVIDER=bedrock
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=neural-chat
BEDROCK_MODEL_ID=anthropic.claude-3-sonnet-20240229-v1:0

# === Admin Email for Reports ===
ADMIN_EMAIL=admin@workping.live

# === Logging ===
LOG_LEVEL=info
SENTRY_DSN=<optional-error-tracking>

# === Security ===
# Set HTTPS/TLS options
CORS_ORIGIN=https://workping.live,https://admin.workping.live
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=900

# === Feature Flags ===
ENABLE_BIOMETRIC=true
ENABLE_OTP=true
ENABLE_2FA=true
ENABLE_PAYMENT=true
