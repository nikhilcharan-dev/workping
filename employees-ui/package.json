{
  "name": "workping-employee-ui",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "WorkPing Employee Portal — React 18 + Vite 5 SPA for browser-based face check-in (react-webcam → 1:1 cosine similarity in face-api-microservice), attendance history heatmap, leave requests with multi-level approval tracking, salary slip download, 2FA setup (TOTP via speakeasy on the server), real-time leave-approval notifications via socket.io-client. Same JWT + refresh-token + Google/Microsoft OAuth stack as admin-ui; role-separation enforced server-side via requireRole.js.",
  "scripts": {
    "dev": "vite --host",
    "build": "vite build",
    "test": "cross-env NODE_OPTIONS=--experimental-vm-modules jest",
    "test:unit": "cross-env NODE_OPTIONS=--experimental-vm-modules jest --testPathIgnorePatterns=integration",
    "test:integration": "cross-env NODE_OPTIONS=--experimental-vm-modules jest --testPathPattern=integration",
    "lint": "eslint . --ext js,jsx --report-unused-disable-directives --max-warnings 0",
    "preview": "vite preview",
    "format": "prettier --write 'src/**/*.{ts,tsx,js,jsx}'",
    "format:check": "prettier --check 'src/**/*.{ts,tsx,js,jsx}'"
  },
  "dependencies": {
    "@hookform/resolvers": "^3.3.4",
    "@nivo/calendar": "^0.99.0",
    "@tanstack/react-table": "^8.17.3",
    "apexcharts": "3.41.0",
    "axios": "^1.7.2",
    "bootstrap": "^5.3.3",
    "clsx": "^2.1.1",
    "cookies-next": "^4.2.1",
    "dayjs": "^1.11.11",
    "moment": "^2.30.1",
    "react": "^18.3.1",
    "react-apexcharts": "^1.4.1",
    "react-bootstrap": "^2.10.2",
    "react-dom": "^18.3.1",
    "react-dropzone": "^14.2.3",
    "react-flatpickr": "^3.10.13",
    "react-helmet-async": "^2.0.5",
    "react-hook-form": "^7.51.4",
    "react-hot-toast": "^2.6.0",
    "react-router-dom": "^6.23.1",
    "react-select": "^5.8.0",
    "react-sweetalert2": "^0.6.0",
    "react-toastify": "^10.0.5",
    "react-webcam": "^7.2.0",
    "simplebar-react": "^3.2.5",
    "socket.io-client": "^4.8.3",
    "yup": "^1.4.0"
  },
  "devDependencies": {
    "@iconify/react": "^4.1.1",
    "@jest/globals": "^29.0.0",
    "@testing-library/jest-dom": "^6.1.5",
    "@testing-library/react": "^14.1.2",
    "@testing-library/user-event": "^14.5.1",
    "@typescript-eslint/eslint-plugin": "^8.58.2",
    "@typescript-eslint/parser": "^8.58.2",
    "@vitejs/plugin-react": "^4.3.1",
    "cross-env": "^7.0.3",
    "eslint": "^8.57.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.4.7",
    "jest": "^29.0.0",
    "jest-environment-jsdom": "^29.0.0",
    "prettier": "^3.3.1",
    "sass": "^1.77.4",
    "vite": "^5.2.13"
  }
}
