# WorkPing Biometric Service — Environment Variables
# Copy this file to .env and fill in the values

# ─── MongoDB ───────────────────────────────────────────────
MONGODB_URI=mongodb+srv://<user>:<pass>@cluster.mongodb.net/<db>?retryWrites=true&w=majority
MONGODB_DB=workping

# ─── Redis ─────────────────────────────────────────────────
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=

# ─── Internal auth ─────────────────────────────────────────
# Shared secret for service-to-service calls and the /dashboard + /ws/stats
# operator endpoints. MUST match centralized-server's INTERNAL_SECRET.
INTERNAL_SECRET=
