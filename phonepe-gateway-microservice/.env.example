# PhonePe Gateway Microservice Configuration

# Server Port
PORT=3000

# Your Backend Configuration
# The URL where this microservice will forward processed payments (webhooks)
ORIGIN=https://your-backend-api.com
ORIGIN_WEBHOOK_URL=https://your-backend-api.com/api/admin/phonepe/webhook
# Secret key for verifying webhooks from this microservice to your backend
ORIGIN_WEBHOOK_SECRET=your_backend_webhook_secret

# PhonePe Business Credentials
# [Production] https://api.phonepe.com/apis/pg
# [Test] https://api-preprod.phonepe.com/apis/pg-sandbox
PHONEPE_BASE_URL=https://api-preprod.phonepe.com/apis/pg-sandbox
PHONEPE_REDIRECT_URI=https://your-frontend-domain.com

# OAuth Credentials
PHONEPE_CLIENT_ID=your_phonepe_client_id
PHONEPE_CLIENT_SECRET=your_phonepe_client_secret
PHONEPE_CLIENT_VERSION=1
PHONEPE_GRANT_TYPE=client_credentials

# Auth Base URI (usually same as base URL for sandbox, different for production)
# [Production] https://api.phonepe.com/apis/identity-manager
# [Test] https://api-preprod.phonepe.com/apis/pg-sandbox
PHONEPE_AUTH_BASE_URL=https://api-preprod.phonepe.com/apis/pg-sandbox

# Microservice Webhook Credentials (Incoming from PhonePe)
WEBHOOK_USERNAME=phonepe_webhook_user
WEBHOOK_PASSWORD=phonepe_webhook_password
# HMAC secret for PhonePe X-Verify header (set in PhonePe merchant dashboard → Webhooks)
PHONEPE_WEBHOOK_SECRET=

# Redis (for webhook idempotency deduplication)
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=

# Valid plan prices in paise (comma-separated). Amounts outside this list are rejected.
# Example: 49900,99900,199900  represents ₹499, ₹999, ₹1999
VALID_PLAN_AMOUNTS_PAISE=49900,99900,199900
