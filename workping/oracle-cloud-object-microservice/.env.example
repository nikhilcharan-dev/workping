# ========== Server ==========
PORT=8000
NODE_ENV=development          # development | production

# ========== Security ==========
API_KEY=                       # Set a strong key; leave blank to disable auth (dev only)
ALLOWED_ORIGINS=http://localhost:3000   # Comma-separated list of allowed CORS origins
RATE_LIMIT_MAX=100             # Max requests per 15-minute window per IP

# ========== Oracle Cloud Infrastructure ==========
COMPARTMENT_ID=ocid1.tenancy.oc1..xxxxx
REGION=ap-hyderabad-1

# OCI SDK config (optional overrides — defaults to .oci/config DEFAULT profile)
OCI_CONFIG_PATH=               # Absolute or relative path to OCI config file
OCI_PROFILE=DEFAULT            # Profile name inside the OCI config file

# ========== Upload ==========
MAX_FILE_SIZE_MB=50            # Max upload size in megabytes
ALLOWED_MIME_TYPES=            # Comma-separated (e.g. image/png,application/pdf). Leave blank to allow all

# ========== Pre-Signed URLs ==========
PRESIGNED_EXPIRY_MINUTES=15    # Pre-signed URL lifetime in minutes

# ========== Logging ==========
LOG_LEVEL=info                 # trace | debug | info | warn | error | fatal
