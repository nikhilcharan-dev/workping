{
  "name": "oracle-cloud-express-for-object-storage",
  "version": "1.0.0",
  "description": "WorkPing Storage — REST proxy for Oracle Cloud Infrastructure Object Storage. Pre-signed URL issuance for direct browser uploads (15-min TTL), helmet + CORS allowlist + per-IP rate-limit (100/15min) + constant-time X-API-KEY auth, multipart upload fallback, Prometheus + CSV metrics export with disk-persisted snapshots survivable across restarts, graceful shutdown flushes metrics, Winston structured logging, OCI SDK reads credentials from mounted ~/.oci config.",
  "main": "app.js",
  "scripts": {
    "start": "node app.js",
    "dev": "nodemon app.js",
    "test": "cross-env NODE_OPTIONS=--experimental-vm-modules jest",
    "test:unit": "cross-env NODE_OPTIONS=--experimental-vm-modules jest --testPathIgnorePatterns=integration",
    "test:integration": "cross-env NODE_OPTIONS=--experimental-vm-modules jest --testPathPattern=integration",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nikhilcharan-dev/oracle-cloud-express.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "bugs": {
    "url": "https://github.com/nikhilcharan-dev/oracle-cloud-express/issues"
  },
  "homepage": "https://github.com/nikhilcharan-dev/oracle-cloud-express#readme",
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "cross-env": "^7.0.3",
    "eslint": "^9.0.0",
    "globals": "^15.0.0",
    "jest": "^29.0.0",
    "nodemon": "^3.0.0",
    "prettier": "^3.0.0",
    "supertest": "^7.0.0"
  },
  "dependencies": {
    "content-disposition": "^2.0.0",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.2.1",
    "helmet": "^8.1.0",
    "morgan": "^1.10.1",
    "multer": "^2.0.2",
    "oci-sdk": "^2.125.2",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3"
  }
}
