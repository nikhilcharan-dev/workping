{
  "name": "mailer-microservice",
  "version": "1.0.0",
  "description": "WorkPing Mailer — Nodemailer SMTP + Handlebars templates + Redis-backed OTP store. Stateless email + OTP delivery: 6-digit OTPs with TTL (email: 30 min, password-reset: 10 min), single-use invalidation on verify, helmet + rate-limit + timing-safe bearer-token auth. Templates: welcome, alerts (info/warning/danger/success), notifications, forgot-password.",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "npx nodemon server.js",
    "test": "cross-env NODE_OPTIONS=--experimental-vm-modules jest",
    "test:unit": "cross-env NODE_OPTIONS=--experimental-vm-modules jest --testPathIgnorePatterns=integration",
    "test:integration": "cross-env NODE_OPTIONS=--experimental-vm-modules jest --testPathPattern=integration",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nikhilcharan-dev/mailer-microservice.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "bugs": {
    "url": "https://github.com/nikhilcharan-dev/mailer-microservice/issues"
  },
  "homepage": "https://github.com/nikhilcharan-dev/mailer-microservice#readme",
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@jest/globals": "^29.7.0",
    "cross-env": "^7.0.3",
    "eslint": "^9.0.0",
    "globals": "^15.0.0",
    "jest": "^29.0.0",
    "prettier": "^3.0.0",
    "supertest": "^7.0.0"
  },
  "dependencies": {
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "handlebars": "^4.7.8",
    "node-cron": "^4.2.1",
    "nodemailer": "^8.0.7",
    "redis": "^5.10.0"
  }
}
