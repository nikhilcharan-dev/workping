# WorkPing Chatbot (WhatsApp) — Environment Variables
# Copy this file to .env and fill in the values

# Server
PORT=3002

# Analytics dashboard credentials
DASHBOARD_USER=admin
# Bcrypt hash of the dashboard password (cost factor 12). Generate with:
#   node -e "const b=require('bcryptjs');console.log(b.hashSync('yourpassword',12))"
DASHBOARD_PASS_HASH=
# JWT secret for signing dashboard session tokens (use a random 32+ char string)
JWT_SECRET=

# CORS — allowed origins (comma-separated)
ORIGIN=http://localhost:5000

# ─── Meta / WhatsApp Cloud API ─────────────────────────────────────────────────
WHATSAPP_VERIFY_TOKEN=           # arbitrary string you set in Meta Developer Console
WHATSAPP_PHONE_NUMBER_ID=        # from Meta Developer Console
WHATSAPP_META_BASE_URI=https://graph.facebook.com/v19.0
WHATSAPP_API_KEY=                # Meta permanent access token
WHATSAPP_APP_SECRET=             # App Secret from Meta Developer Console (for X-Hub-Signature-256)

# ─── LLM Provider ──────────────────────────────────────────────────────────────
# Options: "ollama" | "bedrock" | "custom"
#
# "custom" covers any OpenAI-compatible API. Set CUSTOM_MODEL_REQUEST_FORMAT=openai
# and point CUSTOM_MODEL_BASE_URL at your provider. Examples below.
LLM_PROVIDER=ollama

# ─── Ollama (local / self-hosted) ──────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# ─── AWS Bedrock ───────────────────────────────────────────────────────────────
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
BEDROCK_MODEL_ID=anthropic.claude-3-haiku-20240307-v1:0

# ─── Custom / OpenAI-Compatible (LLM_PROVIDER=custom) ──────────────────────────
#
# ── OpenAI ──────────────────────────────────
# CUSTOM_MODEL_BASE_URL=https://api.openai.com/v1
# CUSTOM_MODEL_API_KEY=sk-...
# CUSTOM_MODEL_NAME=gpt-4o-mini
# CUSTOM_MODEL_REQUEST_FORMAT=openai
# CUSTOM_MODEL_CHAT_ENDPOINT=/chat/completions
#
# ── Groq (free tier, very fast inference) ───
# CUSTOM_MODEL_BASE_URL=https://api.groq.com/openai/v1
# CUSTOM_MODEL_API_KEY=gsk_...
# CUSTOM_MODEL_NAME=llama-3.1-8b-instant
# CUSTOM_MODEL_REQUEST_FORMAT=openai
# CUSTOM_MODEL_CHAT_ENDPOINT=/chat/completions
#
# ── Together AI ─────────────────────────────
# CUSTOM_MODEL_BASE_URL=https://api.together.xyz/v1
# CUSTOM_MODEL_API_KEY=...
# CUSTOM_MODEL_NAME=meta-llama/Llama-3-8b-chat-hf
# CUSTOM_MODEL_REQUEST_FORMAT=openai
# CUSTOM_MODEL_CHAT_ENDPOINT=/chat/completions
#
# ── OpenRouter (proxies 200+ models) ────────
# CUSTOM_MODEL_BASE_URL=https://openrouter.ai/api/v1
# CUSTOM_MODEL_API_KEY=sk-or-...
# CUSTOM_MODEL_NAME=mistralai/mistral-7b-instruct
# CUSTOM_MODEL_REQUEST_FORMAT=openai
# CUSTOM_MODEL_CHAT_ENDPOINT=/chat/completions
#
# ── Mistral AI ──────────────────────────────
# CUSTOM_MODEL_BASE_URL=https://api.mistral.ai/v1
# CUSTOM_MODEL_API_KEY=...
# CUSTOM_MODEL_NAME=mistral-small-latest
# CUSTOM_MODEL_REQUEST_FORMAT=openai
# CUSTOM_MODEL_CHAT_ENDPOINT=/chat/completions
#
# ── Remote Ollama instance ──────────────────
# CUSTOM_MODEL_BASE_URL=http://your-ollama-server:11434
# CUSTOM_MODEL_NAME=qwen2.5:7b
# CUSTOM_MODEL_REQUEST_FORMAT=ollama
# CUSTOM_MODEL_CHAT_ENDPOINT=/api/chat
#
# ── Generic / proprietary server ────────────
# CUSTOM_MODEL_BASE_URL=http://your-model-server:8000
# CUSTOM_MODEL_API_KEY=your-key
# CUSTOM_MODEL_NAME=your-model
# CUSTOM_MODEL_REQUEST_FORMAT=raw
# CUSTOM_MODEL_CHAT_ENDPOINT=/predict
#
CUSTOM_MODEL_BASE_URL=
CUSTOM_MODEL_API_KEY=
CUSTOM_MODEL_NAME=
CUSTOM_MODEL_REQUEST_FORMAT=openai
CUSTOM_MODEL_CHAT_ENDPOINT=/chat/completions
CUSTOM_MODEL_GENERATE_ENDPOINT=/completions
CUSTOM_MODEL_TIMEOUT=60000

# ─── Internal ──────────────────────────────────────────────────────────────────
# Must match INTERNAL_SECRET in centralized-server
INTERNAL_SECRET=

# ─── Redis (BullMQ message queue) ──────────────────────────────────────────────
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
